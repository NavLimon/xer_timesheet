PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# Xero Custom Connection credentials.
XERO_CLIENT_ID=your-client-id
XERO_CLIENT_SECRET=your-client-secret

# Custom Connections use a single organisation. With xero-node, leave tenant ID empty.
XERO_TENANT_ID=

# Payroll timesheet publishing.
# Use Draft for safer testing. Use Approved only when your Xero payroll workflow expects it.
XERO_TIMESHEET_STATUS=Draft

# These accounting defaults are included from the brief, but payroll timesheets do not use them.
XERO_DEFAULT_ACCOUNT_CODE=429
XERO_DEFAULT_TAX_TYPE=INPUT
